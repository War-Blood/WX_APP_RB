/* components/status-tag/index.wxss */
/* 状态标签组件样式 - 支持工厂模式动态配置 */

.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  box-sizing: border-box;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-right: 8rpx;
  flex-shrink: 0;
}

/* ==================== 预设状态样式 ==================== */

/* 待审核 - 橙色 */
.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-pending .status-dot {
  background: #fa8c16;
}

/* 已通过 - 绿色 */
.status-approved {
  background: #f6ffed;
  color: #52c41a;
}

.status-approved .status-dot {
  background: #52c41a;
}

/* 被驳回 - 红色 */
.status-rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.status-rejected .status-dot {
  background: #ff4d4f;
}

/* 草稿 - 灰色 */
.status-draft {
  background: #f5f5f5;
  color: #999;
}

.status-draft .status-dot {
  background: #bbb;
}

/* 已提交 - 蓝色 */
.status-submitted {
  background: #e6f7ff;
  color: #1890ff;
}

.status-submitted .status-dot {
  background: #1890ff;
}

/* 处理中 - 紫色 */
.status-processing {
  background: #f9f0ff;
  color: #722ed1;
}

.status-processing .status-dot {
  background: #722ed1;
}

/* 成功 - 绿色 */
.status-success {
  background: #f6ffed;
  color: #52c41a;
}

.status-success .status-dot {
  background: #52c41a;
}

/* 失败 - 红色 */
.status-failed {
  background: #fff1f0;
  color: #ff4d4f;
}

.status-failed .status-dot {
  background: #ff4d4f;
}

/* 警告 - 黄色 */
.status-warning {
  background: #fffbe6;
  color: #faad14;
}

.status-warning .status-dot {
  background: #faad14;
}

/* 信息 - 蓝色 */
.status-info {
  background: #e6f7ff;
  color: #1890ff;
}

.status-info .status-dot {
  background: #1890ff;
}

/* 自定义状态 - 使用内联样式 */
.status-custom {
  /* 样式由工厂动态生成 */
}
