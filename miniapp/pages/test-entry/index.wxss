/* pages/test-entry/index.wxss */

.entry-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}

/* 顶部 */
.header {
  margin-top: 120rpx;
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 100rpx;
  color: #fff;
  margin-bottom: 20rpx;
}

.app-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

.app-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 12rpx;
  padding: 6rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 20rpx;
  display: inline-block;
}

/* 角色选择 */
.role-section {
  width: 100%;
}

.section-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
  font-weight: 500;
}

/* 当前角色状态 */
.role-status {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.status-badge {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.badge-employee {
  background: rgba(7, 193, 96, 0.2);
  color: #52c41a;
  border: 1rpx solid rgba(7, 193, 96, 0.4);
}

.badge-admin {
  background: rgba(24, 144, 255, 0.2);
  color: #69c0ff;
  border: 1rpx solid rgba(24, 144, 255, 0.4);
}

.clear-btn {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  padding: 12rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 32rpx;
}

.clear-btn:active {
  background: rgba(255, 255, 255, 0.1);
}

.role-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.2s;
}

.role-card:active {
  transform: scale(0.97);
}

.role-icon {
  font-size: 72rpx;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.role-info {
  flex: 1;
}

.role-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.role-desc {
  font-size: 24rpx;
  color: #999;
}

.role-detail {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 6rpx;
}

.role-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

/* 员工卡片左边框强调 */
.employee-card {
  border-left: 8rpx solid #07C160;
}

/* 管理员卡片左边框强调 */
.admin-card {
  border-left: 8rpx solid #1890ff;
}

/* 底部提示 */
.footer-tip {
  margin-top: 60rpx;
  padding-bottom: 60rpx;
}

.tip-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 权限说明 */
.perm-section {
  width: 100%;
  margin-top: 16rpx;
}

.perm-card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.perm-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 8rpx 0;
}

.perm-label {
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
}

.perm-detail {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.5;
}

.perm-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.15);
  margin: 12rpx 0;
}
