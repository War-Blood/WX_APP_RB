<!--
  pages/test-entry/index.wxml
  临时测试入口 — 选择角色后 mock 登录
-->
<view class="entry-page">
  <!-- 顶部标识 -->
  <view class="header">
    <view class="logo-icon">⚙</view>
    <view class="app-title">项目日报系统</view>
    <view class="app-subtitle">测试入口</view>
  </view>

  <!-- 当前角色状态 -->
  <view class="role-status" wx:if="{{currentRole}}">
    <view class="status-badge {{currentRole === 'admin' ? 'badge-admin' : 'badge-employee'}}">
      {{currentRole === 'admin' ? '当前：管理员模式' : '当前：员工模式'}}
    </view>
    <view class="clear-btn" bindtap="onClearAuth">清除并重新选择</view>
  </view>

  <!-- 角色选择卡片 -->
  <view class="role-section">
    <view class="section-title">选择身份进入</view>

    <view class="role-card employee-card" bindtap="onTapEmployee">
      <view class="role-icon">💼</view>
      <view class="role-info">
        <view class="role-name">员工端</view>
        <view class="role-desc">填写项目日报</view>
        <view class="role-detail">可进入：写日报、历史记录</view>
      </view>
      <view class="role-arrow">></view>
    </view>

    <view class="role-card admin-card" bindtap="onTapAdmin">
      <view class="role-icon">🔒</view>
      <view class="role-info">
        <view class="role-name">管理员端</view>
        <view class="role-desc">审核项目日报</view>
        <view class="role-detail">可进入：审核列表</view>
      </view>
      <view class="role-arrow">></view>
    </view>
  </view>

  <!-- 权限说明 -->
  <view class="perm-section">
    <view class="section-title">权限说明</view>
    <view class="perm-card">
      <view class="perm-row">
        <view class="perm-label">员工端</view>
        <view class="perm-detail">填写日报 + 查看自己的历史记录及审核状态</view>
      </view>
      <view class="perm-divider"></view>
      <view class="perm-row">
        <view class="perm-label">管理员端</view>
        <view class="perm-detail">审核所有日报 + 查看所有提交记录</view>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text class="tip-text">当前为测试模式，域名上线后恢复正式登录</text>
  </view>
</view>
