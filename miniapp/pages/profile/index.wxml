<view class="container">

  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar">{{avatarChar}}</view>
    <view class="user-info">
      <view class="user-name">{{userName}}</view>
      <view class="user-role">{{roleText}} · {{department}}</view>
    </view>
  </view>

  <!-- 设置列表 -->
  <view class="section-title">个人信息</view>
  <view class="setting-list">
    <view class="setting-item" bindtap="onEditName">
      <view class="setting-label">姓名</view>
      <view class="setting-value">{{userName}}</view>
      <view class="setting-arrow">›</view>
    </view>
    <view class="setting-divider" />
    <view class="setting-item" bindtap="onEditDept">
      <view class="setting-label">部门</view>
      <view class="setting-value">{{department}}</view>
      <view class="setting-arrow">›</view>
    </view>
  </view>

  <view class="section-title">其他</view>
  <view class="setting-list">
    <view class="setting-item" bindtap="onCopyOpenid">
      <view class="setting-label">用户ID</view>
      <view class="setting-value mono">{{openid || '未登录'}}</view>
      <view class="setting-arrow">›</view>
    </view>
  </view>

  <!-- 退出按钮 -->
  <view class="logout-section">
    <button class="btn-logout" bindtap="onLogout">退出登录</button>
  </view>

</view>
