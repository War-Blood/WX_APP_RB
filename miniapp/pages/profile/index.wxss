/* pages/profile/index.wxss */

.user-card {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background: #fff;
  margin: 30rpx 30rpx 10rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #07C160;
  color: #fff;
  font-size: 44rpx;
  font-weight: 500;
  text-align: center;
  line-height: 100rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.user-role {
  font-size: 24rpx;
  color: #999;
}

.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
  padding: 30rpx 30rpx 12rpx;
}

.setting-list {
  background: #fff;
  margin: 0 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
}

.setting-label {
  font-size: 28rpx;
  color: #333;
  width: 140rpx;
  flex-shrink: 0;
}

.setting-value {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  text-align: right;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.setting-value.mono {
  font-size: 24rpx;
  color: #999;
}

.setting-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 12rpx;
}

.setting-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin-left: 30rpx;
}

.logout-section {
  padding: 60rpx 30rpx;
}

.btn-logout {
  background: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
  border-radius: 12rpx;
  font-size: 30rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.btn-logout::after {
  border: none;
}
