/* pages/home/index.wxss */

.hero-section {
  background: linear-gradient(135deg, #07C160 0%, #06ad56 100%);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  margin: 30rpx 30rpx 20rpx;
  color: #fff;
}

.hero-greeting {
  font-size: 40rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.hero-date {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.hero-role {
  font-size: 24rpx;
  opacity: 0.7;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  padding: 20rpx 30rpx 12rpx;
}

.action-grid {
  display: flex;
  padding: 0 30rpx;
  gap: 20rpx;
}

.action-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 28rpx;
  color: #333;
}

.footer-tip {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
}

.all-features {
  padding: 30rpx;
  text-align: center;
}

.all-features-text {
  display: inline-block;
  background: #fff;
  padding: 24rpx 60rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #07C160;
  font-weight: 500;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
