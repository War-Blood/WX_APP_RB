<view class="container">

  <!-- 顶部欢迎区域 -->
  <view class="hero-section">
    <view class="hero-greeting">你好，{{userName}}</view>
    <view class="hero-date">{{todayStr}}</view>
    <view class="hero-role">当前身份：{{roleText}}</view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions">
    <view class="section-title">快捷入口</view>
    <view class="action-grid">
      <view
        class="action-item"
        wx:for="{{quickActions}}"
        wx:key="name"
        data-page="{{item.page}}"
        bindtap="onQuickAction"
      >
        <view class="action-icon">{{item.icon}}</view>
        <view class="action-text">{{item.name}}</view>
      </view>
    </view>
  </view>

  <!-- 全部功能入口 -->
  <view class="all-features" bindtap="onGoFeatures">
    <view class="all-features-text">查看全部功能 ›</view>
  </view>

</view>
