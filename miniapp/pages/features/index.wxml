<view class="container">

  <view class="page-header">
    <view class="page-title">功能列表</view>
    <view class="page-desc">选择需要使用的功能</view>
  </view>

  <block wx:for="{{sections}}" wx:for-item="section" wx:key="title">
    <view class="section-title">{{section.title}}</view>
    <view class="feature-grid">
      <view
        class="feature-item"
        wx:for="{{section.items}}"
        wx:for-item="feat"
        wx:key="name"
        data-page="{{feat.page}}"
        bindtap="onFeatureTap"
      >
        <view class="feature-icon">{{feat.icon}}</view>
        <view class="feature-name">{{feat.name}}</view>
        <view class="feature-desc">{{feat.desc}}</view>
      </view>
    </view>
  </block>

</view>
