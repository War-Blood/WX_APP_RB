/* pages/features/index.wxss */

.page-header {
  padding: 30rpx 30rpx 10rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
}

.page-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
  padding: 30rpx 30rpx 12rpx;
}

.feature-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
  gap: 16rpx;
}

.feature-item {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  box-sizing: border-box;
}

.feature-icon {
  font-size: 52rpx;
  margin-bottom: 12rpx;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}
