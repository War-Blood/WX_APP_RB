/* pages/employee/report-edit/index.wxss */

/* 顶部 header 卡片 */
.header-card {
  padding: 32rpx;
}

.date-text {
  font-size: 40rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.2;
}

.date-week {
  font-size: 26rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 预填提示 */
.prefill-tip {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #e6f7ff;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #1890ff;
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #1890ff;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

/* 审核通过提示 */
.approved-tip {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #f6ffed;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

/* 表单卡片 */
.form-card {
  padding: 24rpx 32rpx;
}

.form-item {
  padding: 16rpx 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.required-star {
  color: #ff4d4f;
  margin-right: 6rpx;
  font-size: 28rpx;
}

.optional-text {
  font-size: 22rpx;
  font-weight: 400;
  margin-left: 8rpx;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #fafafa;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.form-textarea:focus {
  border-color: #07C160;
  background: #fff;
}

.word-count {
  text-align: right;
  margin-top: 8rpx;
  font-size: 22rpx;
}

/* 只读模式 */
.readonly-card {
  opacity: 0.85;
}

.readonly-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
  padding: 16rpx 20rpx;
  background: #fafafa;
  border-radius: 8rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 驳回卡片 */
.reject-card {
  border-left: 6rpx solid #ff4d4f;
  padding-left: 28rpx;
}

.reject-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #ff4d4f;
  margin-bottom: 12rpx;
}

.reject-reason {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  margin-bottom: 12rpx;
  white-space: pre-wrap;
}

.reject-time {
  font-size: 22rpx;
}

/* 草稿提示 */
.draft-tip {
  text-align: center;
  padding: 12rpx 0;
  font-size: 22rpx;
}

/* 底部按钮 */
.footer-btn {
  padding: 20rpx 0 40rpx;
}

.submit-hint {
  text-align: center;
  margin-top: 16rpx;
  font-size: 24rpx;
}
