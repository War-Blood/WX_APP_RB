<!-- pages/employee/report-edit/index.wxml -->
<view class="container">

  <!-- 顶部日期 & 状态区 -->
  <view class="card header-card">
    <view class="flex-between">
      <view>
        <view class="date-text">{{todayStr}}</view>
        <view class="date-week">{{weekStr}}</view>
      </view>
      <view wx:if="{{existingReport}}">
        <status-tag status="{{existingReport.status}}" />
      </view>
    </view>

    <!-- 预填提示 -->
    <view class="prefill-tip" wx:if="{{isPrefilled && !existingReport}}">
      <view class="tip-icon">i</view>
      <text>已预填上次日报内容，请根据今天情况修改</text>
    </view>

    <!-- 已审核通过提示 -->
    <view class="approved-tip" wx:if="{{existingReport.status === 'approved'}}">
      <text>本日日报已审核通过，如需修改请联系管理员</text>
    </view>
  </view>

  <!-- 日报表单 -->
  <view class="card form-card" wx:if="{{existingReport.status !== 'approved'}}">

    <!-- 字段：今日完成 -->
    <view class="form-item">
      <view class="form-label">
        <text class="required-star">*</text>
        <text>今日完成工作</text>
      </view>
      <textarea
        class="form-textarea"
        placeholder="请描述今日完成的工作内容..."
        value="{{content.todayDone}}"
        data-field="todayDone"
        bindinput="onFieldInput"
        maxlength="1000"
        auto-height
      />
      <view class="word-count text-muted">{{content.todayDone.length || 0}}/1000</view>
    </view>

    <view class="divider" />

    <!-- 字段：明日计划 -->
    <view class="form-item">
      <view class="form-label">
        <text class="required-star">*</text>
        <text>明日工作计划</text>
      </view>
      <textarea
        class="form-textarea"
        placeholder="请描述明日的工作计划..."
        value="{{content.tomorrowPlan}}"
        data-field="tomorrowPlan"
        bindinput="onFieldInput"
        maxlength="1000"
        auto-height
      />
      <view class="word-count text-muted">{{content.tomorrowPlan.length || 0}}/1000</view>
    </view>

    <view class="divider" />

    <!-- 字段：遇到的问题/阻碍（可选） -->
    <view class="form-item">
      <view class="form-label">
        <text>问题与阻碍</text>
        <text class="optional-text text-muted">（选填）</text>
      </view>
      <textarea
        class="form-textarea"
        placeholder="工作中遇到的问题、需要协助的事项..."
        value="{{content.blockers}}"
        data-field="blockers"
        bindinput="onFieldInput"
        maxlength="500"
        auto-height
      />
    </view>

    <view class="divider" />

    <!-- 字段：其他备注（可选） -->
    <view class="form-item">
      <view class="form-label">
        <text>其他备注</text>
        <text class="optional-text text-muted">（选填）</text>
      </view>
      <textarea
        class="form-textarea"
        placeholder="其他需要说明的事项..."
        value="{{content.remarks}}"
        data-field="remarks"
        bindinput="onFieldInput"
        maxlength="300"
        auto-height
      />
    </view>

  </view>

  <!-- 只读展示（审核通过后） -->
  <view class="card form-card readonly-card" wx:if="{{existingReport.status === 'approved'}}">
    <view class="form-item">
      <view class="form-label">今日完成工作</view>
      <view class="readonly-text">{{content.todayDone || '（未填写）'}}</view>
    </view>
    <view class="divider" />
    <view class="form-item">
      <view class="form-label">明日工作计划</view>
      <view class="readonly-text">{{content.tomorrowPlan || '（未填写）'}}</view>
    </view>
    <view class="divider" wx:if="{{content.blockers}}" />
    <view class="form-item" wx:if="{{content.blockers}}">
      <view class="form-label">问题与阻碍</view>
      <view class="readonly-text">{{content.blockers}}</view>
    </view>
    <view class="divider" wx:if="{{content.remarks}}" />
    <view class="form-item" wx:if="{{content.remarks}}">
      <view class="form-label">其他备注</view>
      <view class="readonly-text">{{content.remarks}}</view>
    </view>
  </view>

  <!-- 驳回原因展示 -->
  <view class="card reject-card" wx:if="{{existingReport.status === 'rejected'}}">
    <view class="reject-title">驳回原因</view>
    <view class="reject-reason">{{existingReport.reviewNote || '管理员未填写原因'}}</view>
    <view class="reject-time text-muted">驳回时间：{{existingReport.reviewTimeStr}}</view>
  </view>

  <!-- 草稿提示 -->
  <view class="draft-tip text-muted" wx:if="{{draftSavedAt && existingReport.status !== 'approved'}}">
    草稿已自动保存 {{draftSavedAt}}
  </view>

  <!-- 底部按钮区 -->
  <view class="footer-btn" wx:if="{{existingReport.status !== 'approved'}}">
    <button
      class="btn-primary"
      bindtap="onSubmit"
      disabled="{{submitting || !isContentValid}}"
      loading="{{submitting}}"
    >
      {{existingReport && existingReport.status === 'pending' ? '重新提交' : (existingReport && existingReport.status === 'rejected' ? '修改并重新提交' : '提交日报')}}
    </button>
    <view class="submit-hint text-muted">提交后将通知管理员审核</view>
  </view>

</view>
