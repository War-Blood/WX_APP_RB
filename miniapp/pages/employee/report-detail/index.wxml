<!-- pages/employee/report-detail/index.wxml -->
<view class="container">

  <!-- 日期和状态 -->
  <view class="card header-card flex-between">
    <view>
      <view class="detail-date">{{report.date}}</view>
      <view class="detail-sub text-muted">第 {{report.version || 1}} 次提交</view>
    </view>
    <status-tag status="{{report.status}}" />
  </view>

  <!-- 日报内容 -->
  <view class="card">
    <view class="section">
      <view class="section-title">今日完成工作</view>
      <view class="section-body">{{report.content.todayDone || '（未填写）'}}</view>
    </view>
    <view class="divider" />
    <view class="section">
      <view class="section-title">明日工作计划</view>
      <view class="section-body">{{report.content.tomorrowPlan || '（未填写）'}}</view>
    </view>
    <view wx:if="{{report.content.blockers}}">
      <view class="divider" />
      <view class="section">
        <view class="section-title">问题与阻碍</view>
        <view class="section-body">{{report.content.blockers}}</view>
      </view>
    </view>
    <view wx:if="{{report.content.remarks}}">
      <view class="divider" />
      <view class="section">
        <view class="section-title">其他备注</view>
        <view class="section-body">{{report.content.remarks}}</view>
      </view>
    </view>
  </view>

  <!-- 审核信息 -->
  <view class="card" wx:if="{{report.status !== 'pending'}}">
    <view class="section-title">审核信息</view>
    <view class="meta-row flex-between">
      <text class="text-muted">审核结果</text>
      <status-tag status="{{report.status}}" />
    </view>
    <view class="meta-row flex-between" wx:if="{{report.reviewNote}}">
      <text class="text-muted">备注原因</text>
      <text class="meta-value">{{report.reviewNote}}</text>
    </view>
    <view class="meta-row flex-between">
      <text class="text-muted">审核时间</text>
      <text class="meta-value text-muted">{{report.reviewTimeStr || '-'}}</text>
    </view>
  </view>

  <!-- 提交信息 -->
  <view class="card info-card">
    <view class="meta-row flex-between">
      <text class="text-muted">提交时间</text>
      <text class="meta-value text-muted">{{report.submitTimeStr}}</text>
    </view>
  </view>

</view>
