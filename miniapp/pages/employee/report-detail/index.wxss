/* pages/employee/report-detail/index.wxss */

.header-card {
  padding: 32rpx;
}

.detail-date {
  font-size: 36rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.detail-sub {
  font-size: 24rpx;
}

.section {
  padding: 8rpx 0;
}

.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #555;
  margin-bottom: 16rpx;
}

.section-body {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
}

.meta-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.meta-row:last-child {
  border-bottom: none;
}

.meta-value {
  font-size: 26rpx;
  color: #555;
  max-width: 60%;
  text-align: right;
}

.info-card {
  padding: 24rpx 32rpx;
}
