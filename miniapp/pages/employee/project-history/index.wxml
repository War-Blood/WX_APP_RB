<!-- pages/employee/project-history/index.wxml -->
<view class="container">

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索项目名称"
        value="{{searchKeyword}}"
        bindinput="onSearchChange"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
    </view>
  </view>

  <!-- 日期筛选 -->
  <view class="date-filter">
    <text class="filter-label">日期：</text>
    <picker mode="date" value="{{filterDateStart}}" bindchange="onDateStartChange">
      <view class="date-pill {{filterDateStart ? 'active' : ''}}">
        {{filterDateStart || '开始'}}
      </view>
    </picker>
    <text class="filter-sep">至</text>
    <picker mode="date" value="{{filterDateEnd}}" bindchange="onDateEndChange">
      <view class="date-pill {{filterDateEnd ? 'active' : ''}}">
        {{filterDateEnd || '结束'}}
      </view>
    </picker>
    <text class="clear-btn" bindtap="onClearFilter" wx:if="{{filterDateStart || filterDateEnd || filterProjectName || filterStatus}}">清除</text>
  </view>

  <!-- 状态筛选 -->
  <view class="status-filter">
    <view class="status-tab {{filterStatus === '' ? 'active' : ''}}" data-status="" bindtap="onFilterStatus">全部</view>
    <view class="status-tab {{filterStatus === 'pending' ? 'active' : ''}}" data-status="pending" bindtap="onFilterStatus">待审核</view>
    <view class="status-tab {{filterStatus === 'approved' ? 'active' : ''}}" data-status="approved" bindtap="onFilterStatus">已通过</view>
    <view class="status-tab {{filterStatus === 'rejected' ? 'active' : ''}}" data-status="rejected" bindtap="onFilterStatus">已驳回</view>
  </view>

  <!-- 列表 -->
  <scroll-view
    scroll-y
    class="list-scroll"
    bindscrolltolower="onLoadMore"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
  >
    <!-- 统计概览 -->
    <view class="stats-bar" wx:if="{{list.length > 0}}">
      <view class="stat-item">
        <view class="stat-num">{{list.length}}</view>
        <view class="stat-label">当前条数</view>
      </view>
      <view class="stat-item">
        <view class="stat-num text-success">{{completedCount}}</view>
        <view class="stat-label">已完成</view>
      </view>
      <view class="stat-item">
        <view class="stat-num text-warning">{{ongoingCount}}</view>
        <view class="stat-label">进行中</view>
      </view>
    </view>

    <!-- 日报列表 -->
    <view wx:if="{{list.length > 0}}">
      <view
        class="card project-item"
        wx:for="{{list}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-status="{{item.status}}"
        bindtap="onItemTap"
      >
        <!-- 项目头部 -->
        <view class="item-header flex-between">
          <view class="project-name">{{item.project_name}}</view>
          <view class="status-badge {{item.statusClass}}">
            {{item.statusText}}
          </view>
        </view>

        <!-- 区域 + 日期 -->
        <view class="item-meta">
          <text wx:if="{{item.project_area}}" class="meta-tag">{{item.project_area}}</text>
          <text class="meta-date">{{item.dailyDate}}</text>
          <text wx:if="{{item.today_work_type}}" class="meta-tag type">{{item.today_work_type}}</text>
        </view>

        <!-- 工作内容摘要 -->
        <view class="item-content" wx:if="{{item.work_content}}">
          {{item.work_content}}
        </view>

        <!-- 进度条 -->
        <view class="item-progress">
          <view class="progress-bar-sm">
            <view
              class="progress-fill-sm"
              style="width: {{item.current_progress > 100 ? 100 : (item.current_progress || 0)}}%"
            />
          </view>
          <text class="progress-count text-muted">
            {{item.total_complete_count || 0}}/{{item.need_complete_count || 0}}
          </text>
        </view>

        <!-- 底部：人员 + 提交时间 -->
        <view class="item-footer flex-between">
          <view class="footer-left">
            <text wx:if="{{item.worker1_name}}" class="worker-tag">{{item.worker1_name}}</text>
            <text wx:if="{{item.worker2_name}}" class="worker-tag">{{item.worker2_name}}</text>
            <text wx:if="{{item.person_count}}" class="worker-tag">{{item.person_count}}人</text>
          </view>
          <text class="submit-time text-muted">{{item.submitTimeStr}}</text>
        </view>

        <!-- 驳回原因 -->
        <view class="reject-reason" wx:if="{{item.status === 'rejected' && item.review_note}}">
          <text class="reject-label">驳回原因：</text>
          <text>{{item.review_note}}</text>
        </view>

        <!-- 驳回后重新编辑按钮 -->
        <view class="reject-action" wx:if="{{item.status === 'rejected'}}">
          <button class="btn-reject-edit" data-id="{{item.id}}" bindtap="onEditRejected">修改并重新提交</button>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-wrap" wx:if="{{!loading && list.length === 0}}">
      <view class="empty-icon">📋</view>
      <view class="empty-text">暂无项目日报记录</view>
      <view class="empty-sub text-muted">点击下方按钮填写第一份项目日报</view>
      <button class="btn-primary empty-btn" bindtap="onAddTap">填写项目日报</button>
    </view>

    <!-- 加载更多 -->
    <view class="load-more text-muted" wx:if="{{list.length > 0 && !noMore && !loading}}">上拉加载更多...</view>
    <view class="load-more text-muted" wx:if="{{noMore && list.length > 0}}">已显示全部</view>
  </scroll-view>

  <!-- 底部悬浮新增按钮 -->
  <view class="fab" bindtap="onAddTap">+</view>

</view>
