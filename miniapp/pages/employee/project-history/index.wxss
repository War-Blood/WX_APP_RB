/* pages/employee/project-history/index.wxss */

/* 搜索栏 */
.search-bar {
  margin-bottom: 16rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 日期筛选 */
.date-filter {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-label {
  color: #666;
  flex-shrink: 0;
}

.filter-sep {
  color: #999;
}

.date-pill {
  background: #f5f5f5;
  color: #999;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  min-width: 140rpx;
  text-align: center;
}

.date-pill.active {
  background: #e6f7ff;
  color: #1890ff;
}

.clear-btn {
  color: #ff4d4f;
  font-size: 24rpx;
  margin-left: auto;
}

/* 列表 */
.list-scroll {
  height: calc(100vh - 360rpx);
}

/* 统计栏 */
.stats-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 日报卡片 */
.project-item {
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  cursor: pointer;
}

.project-item:active {
  background: #fafafa;
}

.item-header {
  margin-bottom: 12rpx;
}

.project-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.progress-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

/* 审核状态标签 */
.status-badge {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-approved {
  background: #f6ffed;
  color: #07C160;
}

.status-rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

/* 状态筛选条 */
.status-filter {
  display: flex;
  background: #fff;
  padding: 12rpx 24rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  gap: 8rpx;
}

.status-tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: #666;
  border-radius: 32rpx;
}

.status-tab.active {
  background: #07C160;
  color: #fff;
  font-weight: 500;
}

/* 驳回原因 */
.reject-reason {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: #fff1f0;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #ff4d4f;
  line-height: 1.5;
}

.reject-label {
  font-weight: 500;
}

/* 驳回后编辑按钮 */
.reject-action {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.btn-reject-edit {
  font-size: 24rpx;
  color: #fff;
  background: #ff4d4f;
  border-radius: 32rpx;
  padding: 8rpx 32rpx;
  line-height: 1.4;
  height: auto;
  margin: 0;
  border: none;
}

.btn-reject-edit::after {
  border: none;
}

.btn-reject-edit:active {
  background: #cf1322;
}

.item-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.meta-tag {
  background: #f0f0f0;
  color: #666;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.meta-tag.type {
  background: #fff7e6;
  color: #fa8c16;
}

.meta-date {
  font-size: 24rpx;
  color: #666;
}

.item-content {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
  margin-bottom: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-progress {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.progress-bar-sm {
  flex: 1;
  height: 10rpx;
  background: #f0f0f0;
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill-sm {
  height: 100%;
  background: linear-gradient(90deg, #07C160, #52c41a);
  border-radius: 5rpx;
}

.progress-count {
  font-size: 22rpx;
  min-width: 80rpx;
  text-align: right;
}

.item-footer {
  font-size: 22rpx;
}

.footer-left {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.worker-tag {
  background: #f0f7ff;
  color: #1890ff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.submit-time {
  font-size: 22rpx;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  margin-bottom: 40rpx;
}

.empty-btn {
  width: 320rpx;
  height: 80rpx;
  line-height: 80rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #07C160;
  color: #fff;
  font-size: 56rpx;
  line-height: 100rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.4);
  z-index: 100;
}
