<!-- pages/employee/project-edit/index.wxml -->
<view class="container">

  <!-- 顶部：日期 + 模式提示 -->
  <view class="card header-card">
    <view class="flex-between">
      <view>
        <view class="date-text">{{todayStr}}</view>
        <view class="date-week">{{weekStr}}</view>
      </view>
      <view class="edit-badge" wx:if="{{isEditMode}}">编辑模式</view>
    </view>
    <view class="draft-tip text-muted" wx:if="{{draftSavedAt && !isEditMode}}">
      草稿已自动保存 {{draftSavedAt}}
    </view>
  </view>

  <!-- ===== 基本信息 ===== -->
  <view class="section-title">基本信息</view>
  <view class="card form-card">

    <!-- 日报日期 -->
    <view class="form-item">
      <view class="form-label">
        <text class="required-star">*</text>日报日期
      </view>
      <picker mode="date" value="{{form.daily_time}}" data-field="daily_time" bindchange="onDateChange">
        <view class="picker-display {{form.daily_time ? '' : 'placeholder'}}">
          {{form.daily_time || '请选择日期'}}
        </view>
      </picker>
    </view>

    <view class="divider" />

    <!-- 项目名称 -->
    <view class="form-item">
      <view class="form-label">
        <text class="required-star">*</text>项目名称
      </view>
      <input
        class="form-input"
        placeholder="请输入项目名称"
        value="{{form.project_name}}"
        data-field="project_name"
        bindinput="onFieldInput"
        maxlength="100"
      />
    </view>

    <view class="divider" />

    <!-- 项目区域 -->
    <view class="form-item">
      <view class="form-label">项目所在区域</view>
      <input
        class="form-input"
        placeholder="如：西北区、华东区"
        value="{{form.project_area}}"
        data-field="project_area"
        bindinput="onFieldInput"
        maxlength="100"
      />
    </view>

    <view class="divider" />

    <!-- 相关方单位 -->
    <view class="form-item">
      <view class="form-label">相关方单位</view>
      <input
        class="form-input"
        placeholder="如：国家电网、华能集团"
        value="{{form.related_unit}}"
        data-field="related_unit"
        bindinput="onFieldInput"
        maxlength="100"
      />
    </view>

  </view>

  <!-- ===== 入场与出差 ===== -->
  <view class="section-title">入场与出差</view>
  <view class="card form-card">

    <!-- 入场时间 -->
    <view class="form-item">
      <view class="form-label">入场时间</view>
      <picker mode="date" value="{{form.entry_time}}" data-field="entry_time" bindchange="onDateChange">
        <view class="picker-display {{form.entry_time ? '' : 'placeholder'}}">
          {{form.entry_time || '请选择入场时间'}}
        </view>
      </picker>
    </view>

    <view class="divider" />

    <!-- 初始出差时间 -->
    <view class="form-item">
      <view class="form-label">初始出差时间</view>
      <picker mode="date" value="{{form.initial_business_trip_time}}" data-field="initial_business_trip_time" bindchange="onDateChange">
        <view class="picker-display {{form.initial_business_trip_time ? '' : 'placeholder'}}">
          {{form.initial_business_trip_time || '请选择出差时间'}}
        </view>
      </picker>
    </view>

    <view class="divider" />

    <!-- 项目累计出差天数 / 个人累计出差天数 -->
    <view class="form-row">
      <view class="form-row-item">
        <view class="form-label">项目累计出差天数</view>
        <input
          class="form-input num-input"
          type="number"
          placeholder="0"
          value="{{form.project_business_trip_days}}"
          data-field="project_business_trip_days"
          bindinput="onFieldInput"
        />
      </view>
      <view class="form-row-divider" />
      <view class="form-row-item">
        <view class="form-label">个人累计出差天数</view>
        <input
          class="form-input num-input"
          type="number"
          placeholder="0"
          value="{{form.personal_total_business_trip}}"
          data-field="personal_total_business_trip"
          bindinput="onFieldInput"
        />
      </view>
    </view>

  </view>

  <!-- ===== 作业人员 ===== -->
  <view class="section-title">作业人员</view>
  <view class="card form-card">

    <!-- 作业人员1 -->
    <view class="form-item">
      <view class="form-label">作业人员 1</view>
      <input
        class="form-input"
        placeholder="请输入姓名"
        value="{{form.worker1_name}}"
        data-field="worker1_name"
        bindinput="onFieldInput"
        maxlength="50"
      />
    </view>

    <view class="divider" />

    <!-- 作业人员2 -->
    <view class="form-item">
      <view class="form-label">作业人员 2</view>
      <input
        class="form-input"
        placeholder="请输入姓名"
        value="{{form.worker2_name}}"
        data-field="worker2_name"
        bindinput="onFieldInput"
        maxlength="50"
      />
    </view>

    <view class="divider" />

    <!-- 作业机型 -->
    <view class="form-item">
      <view class="form-label">作业机型</view>
      <input
        class="form-input"
        placeholder="请输入机型型号"
        value="{{form.machine_model}}"
        data-field="machine_model"
        bindinput="onFieldInput"
        maxlength="50"
      />
    </view>

    <view class="divider" />

    <!-- 作业人数 -->
    <view class="form-item">
      <view class="form-label">作业人数</view>
      <input
        class="form-input num-input"
        type="number"
        placeholder="0"
        value="{{form.person_count}}"
        data-field="person_count"
        bindinput="onFieldInput"
      />
    </view>

  </view>

  <!-- ===== 工作内容 ===== -->
  <view class="section-title">工作内容</view>
  <view class="card form-card">

    <!-- 当日从事工作内容 -->
    <view class="form-item">
      <view class="form-label">当日从事工作内容</view>
      <textarea
        class="form-textarea"
        placeholder="请描述当日完成的工作内容..."
        value="{{form.work_content}}"
        data-field="work_content"
        bindinput="onFieldInput"
        maxlength="2000"
        auto-height
      />
      <view class="word-count text-muted">{{form.work_content.length || 0}}/2000</view>
    </view>

    <view class="divider" />

    <!-- 当日工作类型 -->
    <view class="form-item">
      <view class="form-label">当日工作类型</view>
      <picker
        mode="selector"
        range="{{workTypeOptions}}"
        value="{{todayWorkTypeIndex}}"
        bindchange="onTodayWorkTypeChange"
      >
        <view class="picker-display {{todayWorkTypeIndex >= 0 ? '' : 'placeholder'}}">
          {{todayWorkTypeIndex >= 0 ? workTypeOptions[todayWorkTypeIndex] : '请选择工作类型'}}
        </view>
      </picker>
    </view>

    <view class="divider" />

    <!-- 当日工作小结 -->
    <view class="form-item">
      <view class="form-label">当日工作小结</view>
      <textarea
        class="form-textarea"
        placeholder="请对当日工作进行总结..."
        value="{{form.today_work_summary}}"
        data-field="today_work_summary"
        bindinput="onFieldInput"
        maxlength="1000"
        auto-height
      />
      <view class="word-count text-muted">{{form.today_work_summary.length || 0}}/1000</view>
    </view>

    <view class="divider" />

    <!-- 次日计划工作内容 -->
    <view class="form-item">
      <view class="form-label">次日计划工作内容</view>
      <textarea
        class="form-textarea"
        placeholder="请描述次日的工作计划..."
        value="{{form.tomorrow_work_content}}"
        data-field="tomorrow_work_content"
        bindinput="onFieldInput"
        maxlength="1000"
        auto-height
      />
      <view class="word-count text-muted">{{form.tomorrow_work_content.length || 0}}/1000</view>
    </view>

    <view class="divider" />

    <!-- 次日工作类型 -->
    <view class="form-item">
      <view class="form-label">次日工作类型</view>
      <picker
        mode="selector"
        range="{{workTypeOptions}}"
        value="{{tomorrowWorkTypeIndex}}"
        bindchange="onTomorrowWorkTypeChange"
      >
        <view class="picker-display {{tomorrowWorkTypeIndex >= 0 ? '' : 'placeholder'}}">
          {{tomorrowWorkTypeIndex >= 0 ? workTypeOptions[tomorrowWorkTypeIndex] : '请选择工作类型'}}
        </view>
      </picker>
    </view>

  </view>

  <!-- ===== 项目进度 ===== -->
  <view class="section-title">项目进度</view>
  <view class="card form-card">

    <!-- 需要完成总量 / 累计完成量 -->
    <view class="form-row">
      <view class="form-row-item">
        <view class="form-label">项目需要完成总量</view>
        <input
          class="form-input num-input"
          type="number"
          placeholder="0"
          value="{{form.need_complete_count}}"
          data-field="need_complete_count"
          bindinput="onFieldInput"
        />
      </view>
      <view class="form-row-divider" />
      <view class="form-row-item">
        <view class="form-label">项目累计完成量</view>
        <input
          class="form-input num-input"
          type="number"
          placeholder="0"
          value="{{form.total_complete_count}}"
          data-field="total_complete_count"
          bindinput="onFieldInput"
        />
      </view>
    </view>

    <view class="divider" />

    <!-- 当前进度 -->
    <view class="form-item">
      <view class="form-label">项目当前进度（%）</view>
      <input
        class="form-input num-input"
        type="digit"
        placeholder="0.00 ~ 100.00"
        value="{{form.current_progress}}"
        data-field="current_progress"
        bindinput="onFieldInput"
        maxlength="6"
      />
      <!-- 进度条可视化 -->
      <view class="progress-bar-wrap" wx:if="{{form.current_progress}}">
        <view class="progress-bar">
          <view
            class="progress-fill"
            style="width: {{form.current_progress > 100 ? 100 : form.current_progress}}%"
          />
        </view>
        <text class="progress-text">{{form.current_progress}}%</text>
      </view>
    </view>

  </view>

  <!-- ===== 备注 ===== -->
  <view class="section-title">备注</view>
  <view class="card form-card">
    <view class="form-item">
      <view class="form-label">其他备注信息</view>
      <textarea
        class="form-textarea"
        placeholder="其他需要说明的事项..."
        value="{{form.remark}}"
        data-field="remark"
        bindinput="onFieldInput"
        maxlength="500"
        auto-height
      />
      <view class="word-count text-muted">{{form.remark.length || 0}}/500</view>
    </view>
  </view>

  <!-- ===== 底部按钮 ===== -->
  <view class="footer-btn">
    <button
      class="btn-primary"
      bindtap="onSubmit"
      disabled="{{submitting}}"
      loading="{{submitting}}"
    >
      {{isEditMode ? '保存修改' : '提交日报'}}
    </button>
    <button
      wx:if="{{isEditMode}}"
      class="btn-danger"
      bindtap="onDelete"
      style="margin-top: 20rpx;"
    >删除日报</button>
    <view class="submit-hint text-muted">提交后可在历史记录中查看和修改</view>
  </view>

</view>
