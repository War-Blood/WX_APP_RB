<!-- pages/employee/project-detail/index.wxml -->
<view class="container" wx:if="{{!loading && detail}}">

  <!-- 审核状态 -->
  <view class="card review-status-card" wx:if="{{detail.status}}">
    <view class="review-status-row">
      <text class="review-status-label">审核状态</text>
      <view class="status-badge {{detail.statusClass}}">{{detail.statusText}}</view>
    </view>
    <view class="reject-reason" wx:if="{{detail.status === 'rejected' && detail.review_note}}">
      <text class="reject-label">驳回原因：</text>
      <text>{{detail.review_note}}</text>
    </view>
    <button class="btn-reject-edit" wx:if="{{detail.status === 'rejected'}}" bindtap="onEdit">修改并重新提交</button>
    <view class="review-time" wx:if="{{detail.review_time}}">
      <text class="text-muted">审核时间：{{detail.review_time ? detail.review_time.substring(0, 19).replace('T', ' ') : ''}}</text>
    </view>
  </view>

  <!-- 项目概览卡片 -->
  <view class="card overview-card">
    <view class="overview-header">
      <view class="project-name">{{detail.project_name}}</view>
      <view class="progress-circle">
        <text class="progress-num">{{detail.current_progress || 0}}</text>
        <text class="progress-unit">%</text>
      </view>
    </view>

    <!-- 进度条 -->
    <view class="progress-bar-lg">
      <view
        class="progress-fill-lg"
        style="width: {{detail.current_progress > 100 ? 100 : (detail.current_progress || 0)}}%"
      />
    </view>

    <!-- 完成量 -->
    <view class="complete-row">
      <text class="text-muted">完成量：</text>
      <text class="complete-val">{{detail.total_complete_count || 0}}</text>
      <text class="text-muted"> / {{detail.need_complete_count || 0}}</text>
    </view>

    <!-- 基础信息行 -->
    <view class="info-row" wx:if="{{detail.project_area || detail.related_unit}}">
      <text wx:if="{{detail.project_area}}" class="info-tag area">{{detail.project_area}}</text>
      <text wx:if="{{detail.related_unit}}" class="info-tag unit">{{detail.related_unit}}</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="section-title">基本信息</view>
  <view class="card detail-card">
    <view class="detail-row">
      <text class="detail-label">日报日期</text>
      <text class="detail-value">{{detail.daily_time ? detail.daily_time.substring(0, 10) : '-'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">入场时间</text>
      <text class="detail-value">{{detail.entry_time ? detail.entry_time.substring(0, 10) : '-'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">初始出差时间</text>
      <text class="detail-value">{{detail.initial_business_trip_time ? detail.initial_business_trip_time.substring(0, 10) : '-'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">填写人</text>
      <text class="detail-value">{{detail.filler_name || '-'}}</text>
    </view>
  </view>

  <!-- 作业人员 -->
  <view class="section-title">作业人员</view>
  <view class="card detail-card">
    <view class="detail-row">
      <text class="detail-label">作业人员 1</text>
      <text class="detail-value">{{detail.worker1_name || '-'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">作业人员 2</text>
      <text class="detail-value">{{detail.worker2_name || '-'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">作业机型</text>
      <text class="detail-value">{{detail.machine_model || '-'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">作业人数</text>
      <text class="detail-value">{{detail.person_count || 0}} 人</text>
    </view>
  </view>

  <!-- 工作内容 -->
  <view class="section-title">工作内容</view>
  <view class="card detail-card">
    <view class="detail-row" wx:if="{{detail.today_work_type}}">
      <text class="detail-label">工作类型</text>
      <text class="detail-value">{{detail.today_work_type}}</text>
    </view>
    <view class="detail-section" wx:if="{{detail.work_content}}">
      <view class="section-label">当日从事工作内容</view>
      <view class="section-text">{{detail.work_content}}</view>
    </view>
    <view class="detail-section" wx:if="{{detail.today_work_summary}}">
      <view class="section-label">当日工作小结</view>
      <view class="section-text">{{detail.today_work_summary}}</view>
    </view>
    <view class="detail-section" wx:if="{{detail.tomorrow_work_content}}">
      <view class="section-label">次日计划工作内容</view>
      <view class="section-text">{{detail.tomorrow_work_content}}</view>
    </view>
    <view class="detail-row" wx:if="{{detail.tomorrow_work_type}}">
      <text class="detail-label">次日工作类型</text>
      <text class="detail-value">{{detail.tomorrow_work_type}}</text>
    </view>
  </view>

  <!-- 出差天数 -->
  <view class="section-title">出差统计</view>
  <view class="card detail-card">
    <view class="detail-row">
      <text class="detail-label">项目累计出差天数</text>
      <text class="detail-value">{{detail.project_business_trip_days || 0}} 天</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">个人累计出差天数</text>
      <text class="detail-value">{{detail.personal_total_business_trip || 0}} 天</text>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section-title" wx:if="{{detail.remark}}">备注</view>
  <view class="card detail-card" wx:if="{{detail.remark}}">
    <view class="section-text">{{detail.remark}}</view>
  </view>

  <!-- 时间戳 -->
  <view class="timestamp text-muted">
    <text>创建于：{{detail.create_time ? detail.create_time.substring(0, 19).replace('T', ' ') : '-'}}</text>
    <text wx:if="{{detail.update_time !== detail.create_time}}">，更新于：{{detail.update_time ? detail.update_time.substring(0, 19).replace('T', ' ') : '-'}}</text>
  </view>

  <!-- 底部编辑按钮 -->
  <view class="footer-btn">
    <button class="btn-primary" bindtap="onEdit" wx:if="{{detail.status !== 'approved'}}">编辑日报</button>
    <view class="approved-hint text-muted" wx:if="{{detail.status === 'approved'}}">日报已通过审核，不可修改</view>
  </view>

</view>

<!-- 加载状态 -->
<view class="loading-wrap" wx:if="{{loading}}">
  <text class="loading-text">加载中...</text>
</view>
