/* pages/employee/project-detail/index.wxss */

/* 审核状态卡片 */
.review-status-card {
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.review-status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.review-status-label {
  font-size: 28rpx;
  color: #666;
}

.status-badge {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-approved {
  background: #f6ffed;
  color: #07C160;
}

.status-rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.reject-reason {
  padding: 16rpx 20rpx;
  background: #fff1f0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #ff4d4f;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.reject-label {
  font-weight: 500;
}

.btn-reject-edit {
  font-size: 26rpx;
  color: #fff;
  background: #ff4d4f;
  border-radius: 36rpx;
  padding: 12rpx 0;
  margin-top: 8rpx;
  border: none;
}

.btn-reject-edit::after {
  border: none;
}

.btn-reject-edit:active {
  background: #cf1322;
}

.review-time {
  font-size: 22rpx;
}

.approved-hint {
  text-align: center;
  padding: 24rpx;
  font-size: 26rpx;
}

/* 项目概览卡片 */
.overview-card {
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #07C160 0%, #52c41a 100%);
  color: #fff;
  border-radius: 20rpx;
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.project-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  flex: 1;
  margin-right: 20rpx;
  line-height: 1.4;
}

.progress-circle {
  flex-shrink: 0;
  text-align: right;
}

.progress-num {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.progress-unit {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.progress-bar-lg {
  height: 12rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 14rpx;
}

.progress-fill-lg {
  height: 100%;
  background: #fff;
  border-radius: 6rpx;
}

.complete-row {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 14rpx;
}

.complete-val {
  font-weight: 600;
  color: #fff;
}

.info-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.info-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 14rpx;
}

.info-tag.area {
  background: rgba(255,255,255,0.2);
  color: #fff;
}

.info-tag.unit {
  background: rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.85);
}

/* 分节标题 */
.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  padding: 24rpx 0 8rpx 8rpx;
  letter-spacing: 1rpx;
}

/* 详情卡片 */
.detail-card {
  padding: 8rpx 0;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  margin-left: 20rpx;
}

.detail-section {
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-section:last-child {
  border-bottom: none;
}

.section-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.section-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 时间戳 */
.timestamp {
  text-align: center;
  padding: 20rpx;
  font-size: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

/* 底部按钮 */
.footer-btn {
  padding: 16rpx 0 60rpx;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
