/* pages/employee/rejected-edit/index.wxss */

/* 顶部卡片 */
.header-card {
  padding: 28rpx 32rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.3;
}

.page-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.rejected-badge {
  background: #fff2f0;
  color: #ff4d4f;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid #ffccc7;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #07C160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
}

/* 分节标题 */
.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  padding: 24rpx 0 8rpx 8rpx;
  letter-spacing: 1rpx;
}

/* 表单卡片 */
.form-card {
  padding: 8rpx 32rpx 24rpx;
}

.form-item {
  padding: 20rpx 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.required-star {
  color: #ff4d4f;
  margin-right: 6rpx;
  font-size: 28rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #fafafa;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #07C160;
  background: #fff;
}

.form-input.num-input {
  text-align: center;
}

.placeholder {
  color: #bbb;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #fafafa;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.form-textarea:focus {
  border-color: #07C160;
  background: #fff;
}

.word-count {
  text-align: right;
  margin-top: 8rpx;
  font-size: 22rpx;
}

.picker-display {
  height: 80rpx;
  padding: 0 20rpx;
  background: #fafafa;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 80rpx;
}

.picker-display.placeholder {
  color: #bbb;
  line-height: 80rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.form-row-item {
  flex: 1;
}

.form-row-divider {
  width: 24rpx;
}

.progress-bar-wrap {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07C160, #52c41a);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #07C160;
  font-weight: 500;
  margin-left: 16rpx;
  min-width: 80rpx;
  text-align: right;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
}

/* 底部按钮 */
.footer-btn {
  padding: 20rpx 0 60rpx;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.submit-hint {
  text-align: center;
  margin-top: 16rpx;
  font-size: 24rpx;
}
