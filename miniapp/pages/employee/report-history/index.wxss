/* pages/employee/report-history/index.wxss */

.filter-bar {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  margin-bottom: 16rpx;
  border-radius: 0 0 16rpx 16rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 32rpx;
  transition: all 0.2s;
}

.filter-item.active {
  background: #07C160;
  color: #fff;
  font-weight: 500;
}

.list-scroll {
  height: calc(100vh - 220rpx);
}

.report-item {
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  cursor: pointer;
}

.report-item:active {
  background: #f9f9f9;
}

.item-header {
  margin-bottom: 16rpx;
}

.item-date {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.item-preview {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-footer {
  font-size: 22rpx;
}

.arrow-right {
  color: #ccc;
  font-size: 28rpx;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
}

.load-more {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
}
