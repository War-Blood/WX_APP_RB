<!-- pages/employee/report-history/index.wxml -->
<view class="container">

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view
      class="filter-item {{filterStatus === '' ? 'active' : ''}}"
      data-status=""
      bindtap="onFilterChange"
    >全部</view>
    <view
      class="filter-item {{filterStatus === 'pending' ? 'active' : ''}}"
      data-status="pending"
      bindtap="onFilterChange"
    >待审核</view>
    <view
      class="filter-item {{filterStatus === 'approved' ? 'active' : ''}}"
      data-status="approved"
      bindtap="onFilterChange"
    >已通过</view>
    <view
      class="filter-item {{filterStatus === 'rejected' ? 'active' : ''}}"
      data-status="rejected"
      bindtap="onFilterChange"
    >被驳回</view>
  </view>

  <!-- 列表 -->
  <scroll-view
    scroll-y
    class="list-scroll"
    bindscrolltolower="onLoadMore"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
  >
    <view wx:if="{{list.length > 0}}">
      <view
        class="card report-item"
        wx:for="{{list}}"
        wx:key="_id"
        data-id="{{item._id}}"
        bindtap="onItemTap"
      >
        <view class="item-header flex-between">
          <view class="item-date">{{item.date}}</view>
          <status-tag status="{{item.status}}" />
        </view>
        <view class="item-preview">
          {{item.content.todayDone || '（无内容）'}}
        </view>
        <view class="item-footer flex-between">
          <text class="text-muted">提交时间：{{item.submitTimeStr}}</text>
          <text class="arrow-right">></text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-wrap" wx:if="{{!loading && list.length === 0}}">
      <view class="empty-icon">📋</view>
      <view class="empty-text">暂无日报记录</view>
      <view class="empty-sub text-muted">快去写今天的第一份日报吧</view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more text-muted" wx:if="{{list.length > 0 && !noMore}}">加载更多...</view>
    <view class="load-more text-muted" wx:if="{{noMore && list.length > 0}}">已显示全部</view>
  </scroll-view>

</view>
