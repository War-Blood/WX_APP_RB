<!-- pages/admin/review-list/index.wxml -->
<view class="container">

  <!-- 顶部统计 -->
  <view class="card stats-card flex-between">
    <view class="stat-item" bindtap="onFilterChange" data-status="pending">
      <view class="stat-num {{filterStatus === 'pending' ? 'active-pending' : ''}}">{{stats.pending}}</view>
      <view class="stat-label text-muted">待审核</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onFilterChange" data-status="approved">
      <view class="stat-num text-success">{{stats.approved}}</view>
      <view class="stat-label text-muted">已通过</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onFilterChange" data-status="rejected">
      <view class="stat-num text-danger">{{stats.rejected}}</view>
      <view class="stat-label text-muted">已驳回</view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="card search-card">
    <view class="search-row">
      <input class="search-input" placeholder="搜索项目名" value="{{searchProject}}" bindinput="onSearchProjectInput" bindconfirm="onDoSearch" />
      <input class="search-input" placeholder="搜索填写人" value="{{searchFiller}}" bindinput="onSearchFillerInput" bindconfirm="onDoSearch" />
    </view>
    <view class="search-btn" bindtap="onDoSearch">搜索</view>
  </view>

  <!-- 筛选 -->
  <view class="filter-bar">
    <view class="filter-item {{filterStatus === 'pending' ? 'active' : ''}}" data-status="pending" bindtap="onFilterChange">待审核</view>
    <view class="filter-item {{filterStatus === 'approved' ? 'active' : ''}}" data-status="approved" bindtap="onFilterChange">已通过</view>
    <view class="filter-item {{filterStatus === 'rejected' ? 'active' : ''}}" data-status="rejected" bindtap="onFilterChange">已驳回</view>
  </view>

  <!-- 列表 -->
  <scroll-view
    scroll-y
    class="list-scroll"
    bindscrolltolower="onLoadMore"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
  >
    <view wx:if="{{list.length > 0}}">
      <view class="card review-item" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="onItemTap">
        <!-- 顶部：项目名 + 状态 -->
        <view class="item-top flex-between">
          <view class="project-name">{{item.project_name}}</view>
          <view class="status-badge status-{{item.status}}">
            {{item.status === 'pending' ? '待审核' : (item.status === 'approved' ? '已通过' : '已驳回')}}
          </view>
        </view>

        <!-- 信息行 -->
        <view class="info-row">
          <text class="info-tag">{{item.filler_name}}</text>
          <text class="info-date">{{item.dailyDate}}</text>
          <text class="info-area" wx:if="{{item.project_area}}">{{item.project_area}}</text>
        </view>

        <!-- 进度条 -->
        <view class="progress-section">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{item.current_progress || 0}}%"></view>
          </view>
          <text class="progress-text">{{item.progressStr}}</text>
        </view>

        <!-- 工作内容摘要 -->
        <view class="item-preview">{{item.work_content || '（无内容）'}}</view>

        <!-- 底部：时间 + 操作 -->
        <view class="item-footer flex-between">
          <text class="text-muted">{{item.createTimeStr}}</text>
          <view class="quick-actions" wx:if="{{item.status === 'pending'}}" catchtap="stopPropagation">
            <view class="action-btn action-reject" data-id="{{item.id}}" bindtap="onQuickReject">驳回</view>
            <view class="action-btn action-approve" data-id="{{item.id}}" bindtap="onQuickApprove">通过</view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-wrap" wx:if="{{!loading && list.length === 0}}">
      <view class="empty-icon">✅</view>
      <view class="empty-text">暂无{{filterStatus === 'pending' ? '待审核' : ''}}日报</view>
    </view>

    <view class="load-more text-muted" wx:if="{{noMore && list.length > 0}}">已显示全部</view>
  </scroll-view>

</view>
