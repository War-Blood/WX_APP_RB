/* pages/admin/review-list/index.wxss */

.stats-card {
  padding: 28rpx 40rpx;
  margin-bottom: 16rpx;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.2;
}

.stat-num.active-pending {
  color: #fa8c16;
}

.stat-label {
  font-size: 22rpx;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #f0f0f0;
}

/* 搜索 */
.search-card {
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.search-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.search-input {
  flex: 1;
  height: 64rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  background: #f9f9f9;
}

.search-btn {
  background: #07C160;
  color: #fff;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
}

/* 筛选 */
.filter-bar {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 32rpx;
}

.filter-item.active {
  background: #07C160;
  color: #fff;
  font-weight: 500;
}

/* 列表 */
.list-scroll {
  height: calc(100vh - 460rpx);
}

.review-item {
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}

.item-top {
  margin-bottom: 16rpx;
}

.project-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 状态标签 */
.status-badge {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-approved {
  background: #f6ffed;
  color: #07C160;
}

.status-rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.info-tag {
  background: #e6f7ff;
  color: #1890ff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.info-date {
  font-size: 24rpx;
  color: #666;
}

.info-area {
  font-size: 22rpx;
  color: #999;
  padding: 4rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

/* 进度条 */
.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07C160, #52c41a);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #07C160;
  font-weight: 500;
  width: 80rpx;
  text-align: right;
}

.item-preview {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 20rpx;
}

.item-footer {
  font-size: 22rpx;
}

.quick-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-approve {
  background: #07C160;
  color: #fff;
}

.action-reject {
  background: #fff1f0;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #07C160;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
}

.load-more {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
}
