/* pages/admin/review-detail/index.wxss */

/* 顶部概览卡片 */
.header-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  color: #fff;
}

.header-top {
  margin-bottom: 24rpx;
}

.project-name {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-date {
  font-size: 26rpx;
  opacity: 0.8;
}

.status-badge {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-pending {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
}

.status-approved {
  background: rgba(7, 193, 96, 0.2);
  color: #95de64;
}

.status-rejected {
  background: rgba(255, 77, 79, 0.2);
  color: #ffa39e;
}

.header-card .progress-bar {
  flex: 1;
  height: 10rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 5rpx;
  overflow: hidden;
}

.header-card .progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 5rpx;
  transition: width 0.3s;
}

.header-card .progress-text {
  font-size: 26rpx;
  font-weight: 600;
  width: 80rpx;
  text-align: right;
}

.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 信息卡片 */
.info-card {
  padding: 24rpx 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

/* 段落标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #07C160;
}

/* 内容块 */
.content-block {
  margin-bottom: 8rpx;
}

.content-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 进度条（非顶部） */
.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07C160, #52c41a);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #07C160;
  font-weight: 500;
  width: 80rpx;
  text-align: right;
}

/* 审核结果 */
.review-result-card {
  padding: 28rpx 32rpx;
}

.result-row {
  margin-bottom: 16rpx;
}

.result-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 16rpx;
}

.result-value {
  font-size: 26rpx;
  color: #333;
}

/* 表单 */
.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  background: #fafafa;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

/* 操作按钮 */
.action-area {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 0 40rpx;
}

.btn-half {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  border: none;
}
