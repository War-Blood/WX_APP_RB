<!-- pages/admin/review-detail/index.wxml -->
<view class="container">

  <!-- 顶部概览卡片 -->
  <view class="header-card">
    <view class="header-top flex-between">
      <view>
        <view class="project-name">{{report.project_name}}</view>
        <view class="header-date">{{report.dailyDate}}</view>
      </view>
      <view class="status-badge status-{{report.status}}">
        {{report.status === 'pending' ? '待审核' : (report.status === 'approved' ? '已通过' : '已驳回')}}
      </view>
    </view>
    <view class="progress-section">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{report.current_progress || 0}}%"></view>
      </view>
      <text class="progress-text">{{report.progressStr}}</text>
    </view>
  </view>

  <!-- 填报人信息 -->
  <view class="card info-card">
    <view class="info-row">
      <text class="info-label">填报人</text>
      <text class="info-value">{{report.filler_name}}</text>
    </view>
    <view class="info-row" wx:if="{{report.project_area}}">
      <text class="info-label">项目区域</text>
      <text class="info-value">{{report.project_area}}</text>
    </view>
    <view class="info-row" wx:if="{{report.related_unit}}">
      <text class="info-label">相关单位</text>
      <text class="info-value">{{report.related_unit}}</text>
    </view>
    <view class="info-row" wx:if="{{report.entryDate}}">
      <text class="info-label">入场时间</text>
      <text class="info-value">{{report.entryDate}}</text>
    </view>
    <view class="info-row" wx:if="{{report.tripDate}}">
      <text class="info-label">初始出差时间</text>
      <text class="info-value">{{report.tripDate}}</text>
    </view>
  </view>

  <!-- 作业信息 -->
  <view class="card">
    <view class="section-title">作业信息</view>
    <view class="info-row">
      <text class="info-label">作业人员1</text>
      <text class="info-value">{{report.worker1_name || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">作业人员2</text>
      <text class="info-value">{{report.worker2_name || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">作业机型</text>
      <text class="info-value">{{report.machine_model || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">作业人数</text>
      <text class="info-value">{{report.person_count || 0}} 人</text>
    </view>
  </view>

  <!-- 工作内容 -->
  <view class="card">
    <view class="section-title">工作内容</view>
    <view class="content-block">
      <view class="content-label">当日从事工作</view>
      <view class="content-text">{{report.work_content || '（未填写）'}}</view>
    </view>
    <view class="divider" />
    <view class="content-block">
      <view class="content-label">当日工作小结</view>
      <view class="content-text">{{report.today_work_summary || '（未填写）'}}</view>
    </view>
    <view class="divider" />
    <view class="content-block">
      <view class="content-label">次日计划工作</view>
      <view class="content-text">{{report.tomorrow_work_content || '（未填写）'}}</view>
    </view>
  </view>

  <!-- 工作类型 -->
  <view class="card">
    <view class="section-title">工作类型</view>
    <view class="info-row">
      <text class="info-label">当日类型</text>
      <text class="info-value">{{report.today_work_type || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">次日类型</text>
      <text class="info-value">{{report.tomorrow_work_type || '-'}}</text>
    </view>
  </view>

  <!-- 进度统计 -->
  <view class="card">
    <view class="section-title">进度统计</view>
    <view class="info-row">
      <text class="info-label">需完成总数量</text>
      <text class="info-value">{{report.need_complete_count || 0}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">累计完成数量</text>
      <text class="info-value">{{report.total_complete_count || 0}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">当前进度</text>
      <text class="info-value text-success">{{report.progressStr}}</text>
    </view>
  </view>

  <!-- 出差统计 -->
  <view class="card">
    <view class="section-title">出差统计</view>
    <view class="info-row">
      <text class="info-label">项目累计出差天数</text>
      <text class="info-value">{{report.project_business_trip_days || 0}} 天</text>
    </view>
    <view class="info-row">
      <text class="info-label">个人累计出差天数</text>
      <text class="info-value">{{report.personal_total_business_trip || 0}} 天</text>
    </view>
  </view>

  <!-- 备注 -->
  <view class="card" wx:if="{{report.remark}}">
    <view class="section-title">备注</view>
    <view class="content-text">{{report.remark}}</view>
  </view>

  <!-- 已有审核结果 -->
  <view class="card review-result-card" wx:if="{{report.status !== 'pending'}}">
    <view class="result-row flex-between">
      <text class="result-label">审核结果</text>
      <view class="status-badge status-{{report.status}}">
        {{report.status === 'approved' ? '已通过' : '已驳回'}}
      </view>
    </view>
    <view class="result-row" wx:if="{{report.review_note}}">
      <text class="result-label">备注</text>
      <text class="result-value">{{report.review_note}}</text>
    </view>
    <view class="result-row">
      <text class="result-label">审核时间</text>
      <text class="result-value text-muted">{{report.reviewTimeStr}}</text>
    </view>
  </view>

  <!-- 驳回原因输入（仅待审核时显示） -->
  <view class="card" wx:if="{{report.status === 'pending'}}">
    <view class="form-label">审核备注（驳回时请填写原因）</view>
    <textarea
      class="form-textarea"
      placeholder="选填，驳回时请说明原因..."
      value="{{reviewNote}}"
      bindinput="onNoteInput"
      maxlength="200"
      auto-height
    />
  </view>

  <!-- 审核操作按钮 -->
  <view class="action-area" wx:if="{{report.status === 'pending'}}">
    <button
      class="btn-danger btn-half"
      bindtap="onReject"
      loading="{{rejecting}}"
      disabled="{{rejecting || approving}}"
    >驳回</button>
    <button
      class="btn-primary btn-half"
      bindtap="onApprove"
      loading="{{approving}}"
      disabled="{{rejecting || approving}}"
    >审核通过</button>
  </view>

</view>
