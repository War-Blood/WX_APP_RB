/* pages/admin/project-list/index.wxss */

/* 搜索 */
.search-bar {
  margin-bottom: 16rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 日期筛选 */
.date-filter {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-label {
  color: #666;
  flex-shrink: 0;
}

.filter-sep {
  color: #999;
}

.date-pill {
  background: #f5f5f5;
  color: #999;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  min-width: 140rpx;
  text-align: center;
}

.date-pill.active {
  background: #e6f7ff;
  color: #1890ff;
}

.clear-btn {
  color: #ff4d4f;
  font-size: 24rpx;
  margin-left: auto;
}

/* 状态筛选 */
.status-filter {
  display: flex;
  background: #fff;
  padding: 12rpx 24rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  gap: 8rpx;
}

.status-tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: #666;
  border-radius: 32rpx;
}

.status-tab.active {
  background: #07C160;
  color: #fff;
  font-weight: 500;
}

/* 列表 */
.list-scroll {
  height: calc(100vh - 480rpx);
}

/* 统计栏 */
.stats-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 记录卡片 */
.record-item {
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.record-item:active {
  background: #fafafa;
}

.item-header {
  margin-bottom: 12rpx;
}

.project-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

/* 状态标签 */
.status-badge {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-approved {
  background: #f6ffed;
  color: #07C160;
}

.status-rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.info-tag {
  background: #e6f7ff;
  color: #1890ff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.info-date {
  font-size: 24rpx;
  color: #666;
}

.info-area {
  font-size: 22rpx;
  color: #999;
  padding: 4rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

/* 进度条 */
.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.progress-bar {
  flex: 1;
  height: 10rpx;
  background: #f0f0f0;
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07C160, #52c41a);
  border-radius: 5rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #07C160;
  font-weight: 500;
  min-width: 80rpx;
  text-align: right;
}

/* 摘要 */
.item-preview {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 14rpx;
}

/* 底部 */
.item-footer {
  font-size: 22rpx;
}

.footer-left {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.worker-tag {
  background: #f0f7ff;
  color: #1890ff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.load-more {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
}

/* 删除按钮 */
.footer-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.delete-btn {
  color: #ff4d4f;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #fff1f0;
}

.delete-btn:active {
  background: #ffccc7;
}
