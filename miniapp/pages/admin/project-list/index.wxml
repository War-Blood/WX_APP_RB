<!-- pages/admin/project-list/index.wxml -->
<!-- 管理员 - 全部日报记录 -->
<view class="container">

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索项目名" value="{{searchProject}}" bindinput="onSearchProjectInput" bindconfirm="onDoSearch" confirm-type="search" />
    </view>
    <view class="search-input-wrap">
      <text class="search-icon">👤</text>
      <input class="search-input" placeholder="搜索填写人" value="{{searchFiller}}" bindinput="onSearchFillerInput" bindconfirm="onDoSearch" confirm-type="search" />
    </view>
  </view>

  <!-- 日期筛选 -->
  <view class="date-filter">
    <text class="filter-label">日期：</text>
    <picker mode="date" value="{{filterDateStart}}" bindchange="onDateStartChange">
      <view class="date-pill {{filterDateStart ? 'active' : ''}}">{{filterDateStart || '开始'}}</view>
    </picker>
    <text class="filter-sep">至</text>
    <picker mode="date" value="{{filterDateEnd}}" bindchange="onDateEndChange">
      <view class="date-pill {{filterDateEnd ? 'active' : ''}}">{{filterDateEnd || '结束'}}</view>
    </picker>
    <text class="clear-btn" bindtap="onClearFilter" wx:if="{{filterDateStart || filterDateEnd || searchProject || searchFiller || filterStatus}}">清除</text>
  </view>

  <!-- 状态筛选 -->
  <view class="status-filter">
    <view class="status-tab {{filterStatus === '' ? 'active' : ''}}" data-status="" bindtap="onFilterStatus">全部</view>
    <view class="status-tab {{filterStatus === 'pending' ? 'active' : ''}}" data-status="pending" bindtap="onFilterStatus">待审核</view>
    <view class="status-tab {{filterStatus === 'approved' ? 'active' : ''}}" data-status="approved" bindtap="onFilterStatus">已通过</view>
    <view class="status-tab {{filterStatus === 'rejected' ? 'active' : ''}}" data-status="rejected" bindtap="onFilterStatus">已驳回</view>
  </view>

  <!-- 列表 -->
  <scroll-view
    scroll-y
    class="list-scroll"
    bindscrolltolower="onLoadMore"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
  >
    <!-- 统计概览 -->
    <view class="stats-bar" wx:if="{{list.length > 0}}">
      <view class="stat-item">
        <view class="stat-num">{{list.length}}</view>
        <view class="stat-label">当前条数</view>
      </view>
      <view class="stat-item">
        <view class="stat-num text-success">{{completedCount}}</view>
        <view class="stat-label">已完成</view>
      </view>
      <view class="stat-item">
        <view class="stat-num text-warning">{{ongoingCount}}</view>
        <view class="stat-label">进行中</view>
      </view>
    </view>

    <!-- 列表 -->
    <view wx:if="{{list.length > 0}}">
      <view class="card record-item" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="onItemTap">
        <!-- 顶部 -->
        <view class="item-header flex-between">
          <view class="project-name">{{item.project_name}}</view>
          <view class="status-badge {{item.statusClass}}">{{item.statusText}}</view>
        </view>

        <!-- 信息行 -->
        <view class="info-row">
          <text class="info-tag">{{item.filler_name}}</text>
          <text class="info-date">{{item.dailyDate}}</text>
          <text class="info-area" wx:if="{{item.project_area}}">{{item.project_area}}</text>
        </view>

        <!-- 进度 -->
        <view class="progress-section">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{item.current_progress || 0}}%"></view>
          </view>
          <text class="progress-text">{{item.progressStr}}</text>
        </view>

        <!-- 工作摘要 -->
        <view class="item-preview">{{item.work_content || '（无内容）'}}</view>

        <!-- 底部 -->
        <view class="item-footer flex-between">
          <view class="footer-left">
            <text wx:if="{{item.worker1_name}}" class="worker-tag">{{item.worker1_name}}</text>
            <text wx:if="{{item.worker2_name}}" class="worker-tag">{{item.worker2_name}}</text>
          </view>
          <view class="footer-right">
            <text class="text-muted">{{item.submitTimeStr}}</text>
            <text class="delete-btn" data-id="{{item.id}}" data-project="{{item.project_name}}" catchtap="onDeleteTap">删除</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-wrap" wx:if="{{!loading && list.length === 0}}">
      <view class="empty-icon">📋</view>
      <view class="empty-text">暂无日报记录</view>
    </view>

    <view class="load-more text-muted" wx:if="{{noMore && list.length > 0}}">已显示全部</view>
  </scroll-view>

</view>
