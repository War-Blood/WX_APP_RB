<!-- pages/admin/user-manage/index.wxml -->
<!-- 管理员 - 用户管理 -->
<view class="container">

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索姓名 / OpenID"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onDoSearch"
        confirm-type="search"
      />
      <text class="clear-search" wx:if="{{keyword}}" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <!-- 统计 -->
  <view class="stats-bar" wx:if="{{total > 0}}">
    <view class="stat-item">
      <view class="stat-num">{{total}}</view>
      <view class="stat-label">总用户</view>
    </view>
  </view>

  <!-- 用户列表 -->
  <scroll-view
    scroll-y
    class="list-scroll"
    bindscrolltolower="onLoadMore"
  >
    <view wx:if="{{list.length > 0}}">
      <view class="card user-item" wx:for="{{list}}" wx:key="openid">
        <!-- 用户信息 -->
        <view class="user-header">
          <view class="user-avatar-wrap">
            <text class="user-avatar">{{item.user_name ? item.user_name[0] : '?'}}</text>
            <view class="admin-badge" wx:if="{{item.isAdmin}}">管</view>
          </view>
          <view class="user-info">
            <view class="user-name-row">
              <text class="user-name">{{item.user_name || '未设置姓名'}}</text>
              <view class="role-tag {{item.isAdmin ? 'tag-admin' : 'tag-employee'}}">
                {{item.isAdmin ? '管理员' : '员工'}}
              </view>
            </view>
            <view class="user-meta">
              <text class="meta-text" wx:if="{{item.department}}">{{item.department}}</text>
              <text class="meta-text">注册：{{item.createdAtStr}}</text>
            </view>
          </view>
        </view>

        <!-- OpenID（可复制） -->
        <view class="openid-row" bindtap="onCopyOpenid" data-openid="{{item.openid}}">
          <text class="openid-text">{{item.openid}}</text>
          <text class="copy-hint">点击复制</text>
        </view>

        <!-- 操作按钮 -->
        <view class="action-row">
          <button
            class="btn-toggle {{item.isAdmin ? 'btn-remove' : 'btn-add'}}"
            data-openid="{{item.openid}}"
            data-isadmin="{{item.is_admin}}"
            bindtap="onToggleAdmin"
          >{{item.isAdmin ? '取消管理员' : '设为管理员'}}</button>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-wrap" wx:if="{{!loading && list.length === 0}}">
      <view class="empty-icon">👥</view>
      <view class="empty-text">{{keyword ? '未找到匹配用户' : '暂无用户'}}</view>
    </view>

    <view class="load-more" wx:if="{{noMore && list.length > 0}}">共 {{list.length}} / {{total}} 条</view>
    <view class="load-more" wx:if="{{loading}}">加载中...</view>
  </scroll-view>

</view>
