<!-- pages/login/index.wxml -->
<view class="login-container">

  <!-- Logo 区 -->
  <view class="logo-area">
    <view class="logo-icon">
      <view class="logo-inner">日</view>
    </view>
    <view class="logo-title">员工日报</view>
    <view class="logo-sub">简单高效的日报管理工具</view>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <view class="login-card-title">欢迎使用</view>
    <view class="login-card-desc">请使用微信账号登录，享受安全便捷的日报管理</view>

    <button
      class="btn-wechat"
      bindtap="onLoginTap"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      <view class="wechat-btn-inner">
        <view class="wechat-icon"></view>
        <text>{{loading ? '登录中...' : '微信一键登录'}}</text>
      </view>
    </button>

    <view class="privacy-tip">
      登录即表示同意
      <text class="link-text">《用户隐私协议》</text>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="footer-tip">
    <view class="feature-list">
      <view class="feature-item">
        <view class="feature-dot dot-green"></view>
        <text>每日上传日报，自动预填上次内容</text>
      </view>
      <view class="feature-item">
        <view class="feature-dot dot-blue"></view>
        <text>管理员一键审核，结果实时通知</text>
      </view>
      <view class="feature-item">
        <view class="feature-dot dot-orange"></view>
        <text>审核通过自动同步至 WPS 文档</text>
      </view>
    </view>
  </view>

</view>
