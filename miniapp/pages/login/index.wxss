/* pages/login/index.wxss */

.login-container {
  min-height: 100vh;
  background: linear-gradient(160deg, #e8f5e9 0%, #f0f9ff 50%, #fff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx 60rpx;
  box-sizing: border-box;
}

/* Logo 区 */
.logo-area {
  margin-top: 140rpx;
  margin-bottom: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.35);
}

.logo-inner {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.logo-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.logo-sub {
  font-size: 26rpx;
  color: #999;
}

/* 登录卡片 */
.login-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 48rpx;
}

.login-card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.login-card-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

/* 微信登录按钮 */
.btn-wechat {
  width: 100%;
  height: 96rpx;
  background: #07C160;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 24rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-wechat[disabled] {
  background: #a8dfbe;
}

.wechat-btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
}

.privacy-tip {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
}

.link-text {
  color: #07C160;
}

/* 特性说明 */
.footer-tip {
  width: 100%;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: #666;
}

.feature-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-green { background: #07C160; }
.dot-blue  { background: #1890ff; }
.dot-orange { background: #fa8c16; }
