<!-- custom-tab-bar/index.wxml -->
<cover-view class="tab-bar">
  <cover-view
    class="tab-item"
    wx:for="{{list}}"
    wx:key="pagePath"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <cover-view class="tab-dot {{selected === index ? 'active' : ''}}"></cover-view>
    <cover-view class="tab-text {{selected === index ? 'active' : ''}}">{{item.text}}</cover-view>
  </cover-view>
</cover-view>
