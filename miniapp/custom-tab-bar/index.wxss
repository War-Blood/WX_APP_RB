/* custom-tab-bar/index.wxss */

.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  border-top: 1rpx solid #eaeaea;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100rpx;
}

.tab-dot {
  width: 40rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: transparent;
  margin-bottom: 8rpx;
}

.tab-dot.active {
  background: #07C160;
}

.tab-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.2;
}

.tab-text.active {
  color: #07C160;
  font-weight: 600;
}
