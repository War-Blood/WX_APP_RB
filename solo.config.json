{
  "soloMode": {
    "enabled": true,
    "version": "1.0.0",
    "description": "Solo模式配置 - 前后端分离开发模式",
    "backendSpec": {
      "documentPath": "docs/BACKEND_SPEC.md",
      "cacheEnabled": true,
      "cacheTTL": 3600000,
      "autoSync": true,
      "syncInterval": 60000
    },
    "frontend": {
      "miniprogramRoot": "miniapp/",
      "cloudfunctionRoot": "cloudfunctions/",
      "configPath": "config/index.js"
    },
    "backend": {
      "serverPath": "sql/",
      "deployScript": "scripts/deploy-remote.ps1",
      "remoteHost": "111.229.107.123",
      "remoteUser": "ubuntu",
      "remotePath": "/var/www/daily-report/server"
    },
    "features": {
      "autoGenerateApiDocs": true,
      "validateApiContract": true,
      "syncDataModels": true,
      "generateTypeDefinitions": true
    },
    "output": {
      "apiDocsPath": "docs/API.md",
      "typeDefsPath": "types/",
      "mockDataPath": "mock/"
    }
  }
}
