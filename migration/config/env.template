# ============================================================
# 环境变量配置模板
# 请复制此文件为 .env 并填写实际值
# ============================================================

# --------------------------------------------------
# MySQL 数据库配置
# --------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD_HERE
MYSQL_DATABASE=daily_report

# --------------------------------------------------
# 微信小程序配置
# --------------------------------------------------
WECHAT_APPID=YOUR_WECHAT_APPID
WECHAT_SECRET=YOUR_WECHAT_SECRET

# --------------------------------------------------
# JWT 配置
# --------------------------------------------------
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRES_IN=7d

# --------------------------------------------------
# WPS 开放平台配置
# --------------------------------------------------
WPS_API_TOKEN=YOUR_WPS_API_TOKEN
WPS_FILE_ID=YOUR_WPS_FILE_ID
WPS_SHEET_INDEX=0

# --------------------------------------------------
# 订阅消息配置
# --------------------------------------------------
SUBSCRIBE_TEMPLATE_ID=YOUR_SUBSCRIBE_TEMPLATE_ID

# --------------------------------------------------
# Redis 配置（可选）
# --------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --------------------------------------------------
# 服务器配置
# --------------------------------------------------
SERVER_PORT=3000
NODE_ENV=production

# --------------------------------------------------
# 日志配置
# --------------------------------------------------
LOG_LEVEL=info
